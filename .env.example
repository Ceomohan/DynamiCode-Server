PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dynamicode
JWT_SECRET=your_jwt_secret_here
GROQ_API_KEY=your_groq_api_key_here
# Set this to the deployed frontend origin in production.
CLIENT_URL=http://localhost:5173

# Code Execution — Judge0 CE
# Option A (recommended): RapidAPI hosted Judge0 CE — free tier, 50 req/day
#   Sign up at https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_BASE_URL=
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option B: Self-hosted Judge0 instance (no API key needed)
# JUDGE0_BASE_URL=http://localhost:2358
# JUDGE0_API_KEY=
# JUDGE0_API_HOST=

# Optional tuning
# JUDGE0_TIMEOUT_MS=15000
# JUDGE0_POLL_INTERVAL_MS=1500
# JUDGE0_MAX_POLLS=8
